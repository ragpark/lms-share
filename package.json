{
  "name": "lms-share",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "description": "Share to Google Classroom / Microsoft Teams — with lesson packs (URL sequences that resolve to a single shareable link)",
  "engines": { "node": "22.x" },
  "scripts": {
    "dev": "concurrently -k -n web,api -c blue,green \"vite\" \"node --watch --experimental-sqlite server/index.js\"",
    "dev:server": "node --watch --experimental-sqlite server/index.js",
    "build": "vite build",
    "start": "node --experimental-sqlite server/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "express": "^4.21.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.8",
    "@testing-library/react": "^16.0.1",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.0.1",
    "jsdom": "^25.0.0",
    "vite": "^5.4.8",
    "vitest": "^2.1.2"
  }
}
